# Front of House — site environment variables
# Copy to `.env` and fill in. Only PUBLIC_* vars are exposed to the browser.

# Lead capture endpoint (ContRelate local_server `/api/v1/leads`, via its
# Cloudflare tunnel). When set, the contact form POSTs JSON leads here and they
# land in the local SQLite DB on the studio Mac. When unset, the form falls back
# to opening the visitor's mail client.
#
# Local dev example:   PUBLIC_LEAD_ENDPOINT=http://localhost:8001/api/v1/leads
# Production example:   PUBLIC_LEAD_ENDPOINT=https://local.contrelate.<yourdomain>/api/v1/leads
PUBLIC_LEAD_ENDPOINT=

# ── Maître AI concierge ──
# SERVER-ONLY Anthropic key. Powers the /api/maitre serverless route (Claude
# Sonnet 4.6). NEVER prefix this with PUBLIC_ — only PUBLIC_* vars are sent to
# the browser, and an exposed key would be drained. Set it in `.env` for local
# dev and in the Vercel project's Environment Variables for production.
ANTHROPIC_API_KEY=

# Where the Maître widget POSTs the transcript. Defaults to the same-origin
# serverless route /api/maitre (recommended — the key stays server-side). Only
# set this to override, e.g. to route through a different proxy.
PUBLIC_MAITRE_ENDPOINT=
