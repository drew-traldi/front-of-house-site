---
import Logo from "./Logo.astro";
import { nav, site } from "../data/site.ts";
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="hd">
  <div class="container hd__bar">
    <a href="/" class="hd__brand" aria-label={`${site.name} home`}>
      <Logo variant="inline" />
    </a>

    <nav class="hd__nav" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={["hd__link", { "is-active": isActive(item.href) }]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hd__actions">
      <a href="/contact" class="btn btn--primary hd__cta">Scope your build</a>
      <button
        class="hd__toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="hd__mobile" aria-label="Mobile" hidden>
    {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    <a href="/contact" class="btn btn--primary">Scope your build</a>
  </nav>
  <div class="brand-rule"></div>
</header>

<style>
  .hd {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(251, 247, 240, 0.86);
    backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--line-soft);
  }
  .hd__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 74px;
  }
  .hd__brand {
    color: var(--ink);
  }
  .hd__nav {
    display: flex;
    gap: 1.9rem;
    margin-inline: auto;
  }
  .hd__link {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--body);
    padding-block: 0.4rem;
    position: relative;
  }
  .hd__link:hover {
    color: var(--ink);
  }
  .hd__link.is-active {
    color: var(--ink);
  }
  .hd__link.is-active::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: var(--ember);
    border-radius: 2px;
  }
  .hd__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .hd__cta {
    padding: 0.6rem 1.15rem;
    font-size: 0.9rem;
  }
  .hd__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    padding: 0.5rem;
    cursor: pointer;
  }
  .hd__toggle span {
    width: 22px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .hd__mobile {
    display: none;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.5rem var(--gutter) 1.25rem;
    border-top: 1px solid var(--line-soft);
  }
  .hd__mobile a:not(.btn) {
    padding: 0.7rem 0;
    color: var(--ink);
    font-weight: 500;
    border-bottom: 1px solid var(--line-soft);
  }
  .hd__mobile .btn {
    margin-top: 0.75rem;
    justify-content: center;
  }

  @media (max-width: 820px) {
    .hd__nav,
    .hd__cta {
      display: none;
    }
    .hd__toggle {
      display: flex;
    }
    .hd__mobile[data-open] {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.querySelector(".hd__toggle");
  const menu = document.getElementById("mobile-nav");
  toggle?.addEventListener("click", () => {
    const open = menu?.hasAttribute("data-open");
    if (open) {
      menu?.removeAttribute("data-open");
      menu?.setAttribute("hidden", "");
      toggle.setAttribute("aria-expanded", "false");
    } else {
      menu?.setAttribute("data-open", "");
      menu?.removeAttribute("hidden");
      toggle.setAttribute("aria-expanded", "true");
    }
  });
</script>
