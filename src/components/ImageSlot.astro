---
// Photo slot. Drop in a real image via `image` (imported from src/assets,
// preferred: optimized + no layout shift) or a plain `src` path with
// width/height. No image = branded placeholder with the label
// (mirrors the Claude Design image slots).
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  /** imported asset, e.g. `import photo from "../assets/photos/x.jpg"` */
  image?: ImageMetadata;
  src?: string;
  alt?: string;
  label?: string;
  class?: string;
  /** required with `src` to prevent layout shift */
  width?: number;
  height?: number;
  /** index tweaks the placeholder tone so a row of slots varies subtly */
  tone?: number;
}
const {
  image,
  src,
  alt = "",
  label = "Photo",
  class: klass = "",
  width,
  height,
  tone = 0,
} = Astro.props;

const tones = [
  "linear-gradient(150deg, #2b231d 0%, #3a322b 100%)",
  "linear-gradient(150deg, #c75b39 0%, #a8472b 100%)",
  "linear-gradient(150deg, #4a4038 0%, #6b5d4f 100%)",
  "linear-gradient(150deg, #b5853f 0%, #8a6420 100%)",
];
const bg = tones[tone % tones.length];
---

{
  image ? (
    <Image
      class={`slot slot--img ${klass}`}
      src={image}
      alt={alt}
      widths={[480, 800, 1200]}
      sizes="(max-width: 820px) 100vw, 50vw"
      loading="lazy"
    />
  ) : src ? (
    <img
      class={`slot slot--img ${klass}`}
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading="lazy"
    />
  ) : (
    <div
      class={`slot slot--ph ${klass}`}
      style={`--ph-bg:${bg}`}
      role="img"
      aria-label={`${label} (placeholder)`}
    >
      <span class="slot__corner" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
          <rect
            x="3"
            y="5"
            width="18"
            height="14"
            rx="2"
            stroke="currentColor"
            stroke-width="1.6"
          />
          <circle cx="8.5" cy="10" r="1.6" fill="currentColor" />
          <path
            d="M5 17l4.5-4 3 2.5L16 11l3 3"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linejoin="round"
          />
        </svg>
      </span>
      <span class="slot__label">{label}</span>
    </div>
  )
}

<style>
  .slot {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 10px;
    overflow: hidden;
  }
  .slot--img {
    object-fit: cover;
  }
  .slot--ph {
    position: relative;
    background: var(--ph-bg);
    display: flex;
    align-items: flex-end;
    padding: 1.1rem 1.2rem;
    min-height: 120px;
  }
  .slot--ph::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      120% 100% at 80% 0%,
      rgba(251, 247, 240, 0.12),
      transparent 60%
    );
  }
  .slot__corner {
    position: absolute;
    top: 1rem;
    left: 1rem;
    color: rgba(251, 247, 240, 0.6);
  }
  .slot__label {
    position: relative;
    font-family: var(--sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: rgba(251, 247, 240, 0.82);
  }
</style>
