---
import { carePlans, build, locationDiscounts } from "../data/site.ts";
interface Props {
  showBuild?: boolean;
  showLocations?: boolean;
}
const { showBuild = true, showLocations = true } = Astro.props;

const ctaLabel: Record<string, string> = {
  Care: "Start with Care",
  "Care+": "Go Care+",
};
const careFrom = carePlans[0].price;
---

{
  showBuild && (
    <div class="buildpill">
      <div class="buildpill__cell">
        <span class="buildpill__label">One-time build</span>
        <span class="buildpill__price">From {build.from}</span>
        <span class="buildpill__note">You own the code</span>
      </div>
      <div class="buildpill__cell">
        <span class="buildpill__label">Then yearly</span>
        <span class="buildpill__price">From {careFrom} / yr</span>
        <span class="buildpill__note">Hosting &amp; care, no monthly rent</span>
      </div>
    </div>
  )
}

<div class="tiers">
  {
    carePlans.map((plan) => (
      <article class:list={["tier", { "tier--featured": plan.featured }]}>
        <header class="tier__head">
          <h3 class="tier__name">{plan.short}</h3>
          <span
            class:list={["tier__pill", { "tier__pill--pop": plan.featured }]}
          >
            {plan.pill}
          </span>
        </header>

        <p class="tier__price">
          {plan.price}
          <span>{plan.period}</span>
        </p>
        <p class="tier__goodfor">{plan.goodFor}</p>

        <div class="tier__rule" />

        <ul class="tier__features">
          {plan.features.map((f) => (
            <li>
              <svg class="tier__check" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M4 12.5l5 5L20 6.5"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              {f}
            </li>
          ))}
        </ul>

        <a href="/contact" class="tier__cta">
          {ctaLabel[plan.short] ?? `Choose ${plan.short}`}
        </a>
      </article>
    ))
  }
</div>

{
  showLocations && (
    <div class="loc">
      <div class="loc__copy">
        <p class="kicker">More than one location</p>
        <h3 class="loc__h">
          One panel,<br />all your sites.
        </h3>
        <p>
          Run every location's site from a single login, and the more you bring
          on, the less the yearly care costs on each. The build stays priced to
          each site; the discount applies to care.
        </p>
      </div>
      <div class="loc__grid">
        {locationDiscounts.map((d, i) => {
          const pct = d.off.match(/\d+%/)?.[0] ?? d.off;
          const sites = d.range.replace(/ locations?/, "").replace("or more", "+");
          return (
            <div class:list={["loc__cell", { "loc__cell--top": i === 2 }]}>
              <span class="loc__range">{sites} sites</span>
              <span class="loc__pct">{pct}</span>
              <span class="loc__off">off care</span>
            </div>
          );
        })}
      </div>
    </div>
  )
}

<style>
  /* ── Build / yearly pill ── */
  .buildpill {
    display: flex;
    width: fit-content;
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bone);
    margin: 0 auto 2.5rem;
  }
  .buildpill__cell {
    padding: 1.05rem 1.9rem;
  }
  .buildpill__cell + .buildpill__cell {
    border-left: 1px solid var(--line);
  }
  .buildpill__label {
    display: block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.35rem;
  }
  .buildpill__price {
    display: block;
    font-family: var(--display);
    font-size: 1.85rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1;
  }
  .buildpill__note {
    display: block;
    font-size: 0.74rem;
    color: var(--muted);
    margin-top: 0.4rem;
  }

  /* ── Care plans ── */
  .tiers {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    align-items: start;
    max-width: 760px;
    margin-inline: auto;
  }
  .tier {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 2.2rem 2rem;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .tier--featured {
    background: var(--ink);
    border-color: var(--ink);
    box-shadow: 0 18px 40px rgba(34, 28, 24, 0.22);
    transform: translateY(-10px);
  }

  .tier__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1.4rem;
  }
  .tier__name {
    font-family: var(--display);
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0;
    line-height: 1;
  }
  .tier--featured .tier__name {
    color: var(--bone);
  }
  .tier__pill {
    flex: none;
    white-space: nowrap;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 0.32rem 0.75rem;
  }
  .tier__pill--pop {
    color: var(--ink);
    background: var(--ember);
    border-color: var(--ember);
  }

  .tier__price {
    font-family: var(--display);
    font-size: 3.4rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 0.4rem;
    line-height: 1;
  }
  .tier--featured .tier__price {
    color: var(--bone);
  }
  .tier__price span {
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--muted);
  }
  .tier__goodfor {
    font-size: 0.92rem;
    color: var(--body);
    line-height: 1.55;
    min-height: 2.8em;
    margin: 0 0 1.6rem;
  }
  .tier--featured .tier__goodfor {
    color: var(--muted-on-ink);
  }
  .tier__rule {
    height: 1px;
    background: var(--line);
    margin-bottom: 1.5rem;
  }
  .tier--featured .tier__rule {
    background: var(--ink-border);
  }

  .tier__features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    flex: 1;
  }
  .tier__features li {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--body);
  }
  .tier--featured .tier__features li {
    color: var(--bone);
  }
  .tier__check {
    flex: none;
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.14em;
    color: var(--ember);
  }

  .tier__cta {
    text-align: center;
    padding: 0.85rem 1rem;
    border-radius: 6px;
    font-family: var(--sans);
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    border: 1px solid var(--ink);
    color: var(--ink);
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }
  .tier__cta:hover {
    background: var(--ink);
    color: var(--paper);
  }
  .tier--featured .tier__cta {
    background: var(--ember);
    border-color: var(--ember);
    color: var(--paper);
  }
  .tier--featured .tier__cta:hover {
    background: var(--ember-deep);
    border-color: var(--ember-deep);
  }

  /* ── Multi-location ── */
  .loc {
    margin-top: 2.5rem;
    background: var(--bone);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: clamp(1.8rem, 4vw, 3rem);
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
  }
  .loc__h {
    font-size: 2.2rem;
    margin: 0 0 1rem;
    line-height: 1.05;
  }
  .loc__copy p {
    color: var(--body);
    margin: 0;
  }
  .loc__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .loc__cell {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 1.6rem 1.2rem;
    text-align: center;
  }
  .loc__cell--top {
    background: var(--ink);
    border-color: var(--ink);
  }
  .loc__range {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.7rem;
  }
  .loc__pct {
    display: block;
    font-family: var(--display);
    font-size: 2.6rem;
    font-weight: 600;
    color: var(--ember);
    line-height: 1;
  }
  .loc__cell--top .loc__pct {
    color: var(--brass);
  }
  .loc__off {
    display: block;
    font-size: 0.78rem;
    color: var(--muted);
    margin-top: 0.4rem;
  }

  @media (max-width: 900px) {
    .tiers {
      grid-template-columns: 1fr;
    }
    .tier--featured {
      transform: none;
    }
    .loc {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
  @media (max-width: 520px) {
    .buildpill {
      display: flex;
      width: 100%;
    }
    .buildpill__cell {
      flex: 1;
      padding: 0.95rem 1.1rem;
    }
    .buildpill__price {
      font-size: 1.5rem;
    }
    .loc__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
