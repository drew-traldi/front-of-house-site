---
// The FOH frame around every spec demo: slim ink bar, always visible.
// FOH-branded per FOH-DESIGN.md (the demo below it is NOT FOH-branded).
// personalize.js fills [data-foh-for] and the [data-foh-cta] href.
import Logo from "../Logo.astro";

interface Props {
  templateLabel: string;
}
const { templateLabel } = Astro.props;
---

<header class="foh-bar">
  <a class="foh-bar__brand" href="/templates">
    <Logo variant="mark" theme="reversed" />
    <span class="foh-bar__word">Front of House</span>
  </a>
  <p class="foh-bar__label">
    {templateLabel} spec template · <span data-foh-for>try it with your name</span>
  </p>
  <div class="foh-bar__actions">
    <button type="button" class="foh-bar__edit" data-foh-edit>
      Change details
    </button>
    <button
      type="button"
      class="foh-bar__icon"
      data-foh-vibe
      aria-label="Switch vibe"
      title="Switch vibe"
    >
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
        <path
          d="M12 3a9 9 0 1 0 0 18c1.1 0 2-.9 2-2 0-.55-.22-1.05-.59-1.41-.36-.36-.58-.86-.58-1.42 0-1.1.9-2 2-2h2.36A3.8 3.8 0 0 0 21 10.36 9 9 0 0 0 12 3Z"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linejoin="round"
        />
        <circle cx="8" cy="10" r="1.15" fill="currentColor" />
        <circle cx="12" cy="7.5" r="1.15" fill="currentColor" />
        <circle cx="16" cy="10" r="1.15" fill="currentColor" />
      </svg>
    </button>
    <button
      type="button"
      class="foh-bar__icon"
      data-foh-share
      aria-label="Copy link to this version"
      title="Copy link to this version"
    >
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
        <path
          d="M10.5 13.5 13.5 10.5M8.8 15.2l-1.6 1.6a3.11 3.11 0 0 1-4.4-4.4l3.2-3.2a3.11 3.11 0 0 1 4.4 0M15.2 8.8l1.6-1.6a3.11 3.11 0 0 1 4.4 4.4l-3.2 3.2a3.11 3.11 0 0 1-4.4 0"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linecap="round"
        />
      </svg>
      <span class="foh-bar__copied" data-foh-copied hidden>Copied</span>
    </button>
    <a class="foh-bar__cta" data-foh-cta href="/contact">Get this built</a>
  </div>
</header>

<style>
  .foh-bar {
    position: sticky;
    top: 0;
    z-index: 80;
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding: 0.55rem clamp(1rem, 3vw, 1.8rem);
    background: #221c18;
    color: #f4ecdd;
    border-bottom: 2px solid #c75b39;
  }
  .foh-bar__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    flex: none;
  }
  .foh-bar__brand :global(.logo__awning) {
    width: 1.9rem;
  }
  .foh-bar__word {
    font-family: "Cormorant", Georgia, serif;
    font-weight: 600;
    font-size: 1.12rem;
    color: #f4ecdd;
    white-space: nowrap;
  }
  .foh-bar__label {
    margin: 0;
    font-family: "Inter Variable", "Inter", "Helvetica Neue", sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #c9bba0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
    flex: 1;
  }
  .foh-bar__label [data-foh-for] {
    color: #f4ecdd;
  }
  .foh-bar__actions {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    flex: none;
    margin-left: auto;
  }
  .foh-bar__edit,
  .foh-bar__cta,
  .foh-bar__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    font-family: "Inter Variable", "Inter", "Helvetica Neue", sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.42rem 1.05rem;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease,
      border-color 0.18s ease, transform 0.16s ease;
  }
  .foh-bar__icon {
    position: relative;
    min-width: 44px;
    padding: 0.42rem;
    background: transparent;
    color: #c9bba0;
    border: 1.5px solid #3a322b;
  }
  .foh-bar__icon:hover {
    color: #f4ecdd;
    border-color: #c9bba0;
  }
  .foh-bar__copied {
    position: absolute;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #f4ecdd;
    color: #221c18;
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.2rem 0.55rem;
    border-radius: 6px;
    white-space: nowrap;
  }
  .foh-bar__edit {
    background: transparent;
    color: #f4ecdd;
    border: 1.5px solid #3a322b;
  }
  .foh-bar__edit:hover {
    border-color: #c9bba0;
  }
  .foh-bar__cta {
    background: #c75b39;
    color: #fbf7f0;
    border: 1.5px solid transparent;
    text-decoration: none;
  }
  .foh-bar__cta:hover {
    background: #a8472b;
  }
  .foh-bar__cta:active,
  .foh-bar__edit:active {
    transform: translateY(1px);
  }
  .foh-bar :is(a, button):focus-visible {
    outline: 2.5px solid #c75b39;
    outline-offset: 3px;
  }

  @media (max-width: 720px) {
    .foh-bar__label {
      display: none;
    }
    .foh-bar {
      gap: 0.55rem;
    }
    .foh-bar__brand {
      margin-right: auto;
    }
    .foh-bar__edit {
      padding-inline: 0.75rem;
    }
  }
  @media (max-width: 480px) {
    .foh-bar__word {
      display: none;
    }
    .foh-bar [data-foh-share] {
      display: none;
    }
    .foh-bar__cta {
      padding-inline: 0.8rem;
    }
  }
</style>
