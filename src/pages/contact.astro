---
import Base from "../layouts/Base.astro";
import { site, carePlans } from "../data/site.ts";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact Front of House",
  description:
    "Scope your restaurant website build with Front of House. Custom websites you own from $2,000, then flat yearly care from $450.",
  url: `${site.url}/contact`,
  mainEntity: {
    "@id": `${site.url}/#organization`,
  },
};
---

<Base
  title="Contact"
  description="Scope your restaurant website build with Front of House. Custom sites you own from $2,000, flat yearly care from $450. Tell us about your restaurant and we'll come back with a plan."
  jsonLd={jsonLd}
>
  <section id="form" class="phead">
    <div class="container phead__grid">
      <div>
        <p class="kicker">Scope your build</p>
        <h1>Ready to own your restaurant website?</h1>
        <p class="lede">
          Tell us about your restaurant and what you need. We'll come back with
          a scope, a price, a recommended Care tier, and next steps, usually
          within a business day. Custom builds from $2,000, flat yearly care
          from $450.
        </p>

        <ul class="direct">
          <li>
            <span class="direct__label">Email</span>
            <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
          </li>
          <li>
            <span class="direct__label">Phone</span>
            <a href={site.contact.phoneHref}>{site.contact.phone}</a>
          </li>
        </ul>
      </div>

      <!--
        Lead capture: posts to the Front of House lead endpoint (ContRelate's
        local_server `/api/v1/leads`, reached via its Cloudflare tunnel), which
        writes to a local SQLite DB on the studio Mac. Set the URL at build time:
          PUBLIC_LEAD_ENDPOINT=https://<tunnel-host>/api/v1/leads
        If it's unset or the POST fails, the form falls back to opening the
        visitor's mail client, pre-filled, so it always works.
      -->
      <form
        class="form card"
        id="lead-form"
        data-endpoint={import.meta.env.PUBLIC_LEAD_ENDPOINT ?? ""}
      >
        <div class="field">
          <label for="name">Your name</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            aria-describedby="name-err"
          />
          <span class="field__err" id="name-err" role="alert"></span>
        </div>
        <div class="field-row">
          <div class="field">
            <label for="restaurant">Restaurant</label>
            <input
              id="restaurant"
              name="restaurant"
              type="text"
              autocomplete="organization"
            />
          </div>
          <div class="field">
            <label for="locations">Locations</label>
            <input id="locations" name="locations" type="number" min="1" value="1" />
          </div>
        </div>
        <div class="field-row">
          <div class="field">
            <label for="email">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              aria-describedby="email-err"
            />
            <span class="field__err" id="email-err" role="alert"></span>
          </div>
          <div class="field">
            <label for="phone">Phone</label>
            <input id="phone" name="phone" type="tel" autocomplete="tel" />
          </div>
        </div>
        <div class="field">
          <label for="tier">Care plan</label>
          <select id="tier" name="tier">
            <option value="">Not sure yet, help me choose</option>
            {carePlans.map((t) => <option value={t.name}>{t.name}</option>)}
          </select>
        </div>
        <div class="field">
          <label for="message">What do you need?</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            placeholder="New site, a refresh, photos, branding…"></textarea>
        </div>
        <button type="submit" class="btn btn--primary form__submit">
          Send it over
        </button>
        <p class="form__note" id="form-note" role="status" aria-live="polite" hidden></p>
      </form>
    </div>
  </section>
</Base>

<style>
  .phead {
    padding-block: clamp(3rem, 7vw, 5rem);
  }
  .phead__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .phead h1 {
    max-width: 14ch;
  }
  .phead .lede {
    margin-top: 1rem;
  }
  .direct {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: flex;
    gap: 2.5rem;
  }
  .direct__label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.3rem;
  }
  .direct a {
    font-weight: 600;
    color: var(--ink);
  }
  .direct a:hover {
    color: var(--ember);
  }

  .form {
    background: #fff;
    box-shadow: var(--shadow);
  }
  .field {
    margin-bottom: 1rem;
    flex: 1;
  }
  .field-row {
    display: flex;
    gap: 1rem;
  }
  label {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 0.4rem;
  }
  input,
  select,
  textarea {
    width: 100%;
    font: inherit;
    font-size: 0.98rem;
    color: var(--ink);
    background: var(--paper);
    border: 1.5px solid var(--line);
    border-radius: var(--radius-sm);
    padding: 0.7rem 0.85rem;
    transition: border-color 0.16s ease, box-shadow 0.16s ease;
  }
  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--ember);
    box-shadow: 0 0 0 3px rgba(199, 91, 57, 0.14);
  }
  /* Invalid chrome only after the user has blurred or tried to submit —
     never red borders on first paint. Mirrored by the JS aria-invalid flag. */
  input[aria-invalid="true"],
  input:user-invalid {
    border-color: var(--danger);
  }
  input[aria-invalid="true"]:focus,
  input:user-invalid:focus {
    box-shadow: 0 0 0 3px rgba(178, 49, 34, 0.16);
  }
  .field__err {
    display: block;
    min-height: 1.1rem;
    margin-top: 0.35rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--danger);
  }
  textarea {
    resize: vertical;
  }
  .form__submit[aria-disabled="true"] {
    opacity: 0.7;
    cursor: progress;
  }
  .form__submit {
    width: 100%;
    justify-content: center;
    margin-top: 0.5rem;
  }
  .form__note {
    margin: 0.9rem 0 0;
    font-size: 0.9rem;
    text-align: center;
    color: var(--body);
  }
  .form__note[data-state="ok"] {
    color: var(--ember-deep);
    font-weight: 600;
  }

  @media (max-width: 820px) {
    .phead__grid {
      grid-template-columns: 1fr;
    }
    .direct {
      gap: 2rem;
    }
  }
  @media (max-width: 520px) {
    .field-row {
      flex-direction: column;
      gap: 0;
    }
  }
</style>

<script is:inline define:vars={{ to: site.contact.email }}>
  const form = document.getElementById("lead-form");
  const note = document.getElementById("form-note");
  const submit = form?.querySelector(".form__submit");

  // Pattern A: no-JS users keep the browser's native validation; now that JS
  // is here, we repaint errors ourselves instead of the browser's bubbles.
  if (form) form.noValidate = true;

  // Arriving from a spec template ("Get this built"): prefill the form with
  // what they built so sales sees exactly what they want. Never overwrite
  // anything the visitor already typed.
  {
    const q = new URLSearchParams(window.location.search);
    const tpl = q.get("template");
    if (tpl) {
      const restaurant = q.get("restaurant") || "";
      const city = q.get("city") || "";
      const vibe = q.get("vibe") || "";
      const tag = q.get("tag") || "";
      const rInput = document.getElementById("restaurant");
      if (rInput && !rInput.value && restaurant) rInput.value = restaurant;
      const msg = document.getElementById("message");
      if (msg && !msg.value) {
        let text = `I customized the ${tpl} spec template`;
        if (restaurant) text += ` as ${restaurant}`;
        if (city) text += ` in ${city}`;
        text += vibe ? `, ${vibe} vibe.` : ".";
        if (tag) text += ` Tagline: "${tag}".`;
        text += " Let's build the real thing.";
        msg.value = text;
      }
    }
  }

  // Fields that get inline, per-field validation.
  const validated = ["name", "email"]
    .map((id) => document.getElementById(id))
    .filter(Boolean);

  // Adaptive, subrule-specific messages beat a single catch-all.
  function messageFor(input) {
    const v = input.validity;
    if (v.valid) return "";
    if (input.id === "name") {
      return "Add your name so we know who we're talking to.";
    }
    if (input.id === "email") {
      if (v.valueMissing) return "Add your email so we can reach you.";
      return "That doesn't look like a complete email address.";
    }
    return "Please check this field.";
  }

  function setError(input, msg) {
    const err = document.getElementById(`${input.id}-err`);
    if (msg) {
      input.setAttribute("aria-invalid", "true");
      if (err) err.textContent = msg;
    } else {
      input.removeAttribute("aria-invalid");
      if (err) err.textContent = "";
    }
    return !msg;
  }

  validated.forEach((input) => {
    // First blur after editing runs the constraint.
    input.addEventListener("blur", () => setError(input, messageFor(input)));
    // Once invalid, re-validate on input so the error clears as soon as it's
    // fixed, without making the user blur again.
    input.addEventListener("input", () => {
      if (input.getAttribute("aria-invalid") === "true") {
        setError(input, messageFor(input));
      }
    });
  });

  function setSubmitting(on) {
    if (!submit) return;
    submit.disabled = on;
    submit.setAttribute("aria-disabled", String(on));
    submit.textContent = on ? "Sending…" : "Send it over";
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Validate every wired field; show all errors, focus the first bad one.
    let firstInvalid = null;
    validated.forEach((input) => {
      const ok = setError(input, messageFor(input));
      if (!ok && !firstInvalid) firstInvalid = input;
    });
    if (firstInvalid) {
      firstInvalid.focus();
      showNote("A couple of fields need a look.", "err");
      return;
    }

    const data = Object.fromEntries(new FormData(form).entries());
    const endpoint = form.getAttribute("data-endpoint");

    setSubmitting(true);
    showNote("Sending your details…", "");

    if (endpoint) {
      try {
        const res = await fetch(endpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        if (res.ok) {
          form.reset();
          setSubmitting(false);
          showNote("Thanks, we'll be in touch within a business day.", "ok");
          return;
        }
      } catch (_) {
        /* fall through to mailto */
      }
    }

    // No-backend fallback: open the visitor's email client, pre-filled.
    const subject = `New build inquiry: ${data.restaurant || data.name}`;
    const body = [
      `Name: ${data.name}`,
      `Restaurant: ${data.restaurant || "n/a"}`,
      `Locations: ${data.locations || "n/a"}`,
      `Email: ${data.email}`,
      `Phone: ${data.phone || "n/a"}`,
      `Interested in: ${data.tier || "Not sure yet"}`,
      "",
      `${data.message || ""}`,
    ].join("\n");
    window.location.href = `mailto:${to}?subject=${encodeURIComponent(
      subject
    )}&body=${encodeURIComponent(body)}`;
    setSubmitting(false);
    showNote("Opening your email app to send. Almost there.", "ok");
  });

  function showNote(msg, state) {
    if (!note) return;
    note.textContent = msg;
    note.hidden = false;
    note.setAttribute("data-state", state);
  }
</script>
