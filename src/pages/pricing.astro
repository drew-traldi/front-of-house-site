---
import Base from "../layouts/Base.astro";
import Tiers from "../components/Tiers.astro";
import CtaBand from "../components/CtaBand.astro";
import {
  carePlans,
  build,
  buildScope,
  buildBands,
  comparison,
  faq,
} from "../data/site.ts";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.pricing.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};
---

<Base
  title="Pricing"
  description="Buy your restaurant website outright from $2,000, then a flat $450/year to host and keep it sharp. No $200–$500 monthly rental. You own the code."
  jsonLd={jsonLd}
>
  <section class="phead">
    <div class="container">
      <p class="kicker">Pricing</p>
      <h1>How much does a restaurant website cost?</h1>
      <p class="lede">
        A custom website you own outright from $2,000, then a flat $450/year to
        keep it hosted and current. No $200 to $500 monthly rental, ever. Make
        changes yourself or ask Maitre.
      </p>
    </div>
  </section>

  <section id="plans" class="section section--tight">
    <div class="container pricing-body">
      <Tiers showBuild={true} showLocations={true} />
    </div>
  </section>

  <!-- ── What a build runs ── -->
  <section id="build" class="section surface-bone">
    <div class="container">
      <header class="head head--center">
        <p class="kicker">The build</p>
        <h2>Priced to your restaurant.</h2>
        <p class="lede" style="margin-inline:auto;">
          Every restaurant is different, so the build is scoped, not boxed.
          Three things move the price:
        </p>
      </header>

      <div class="scope">
        {
          buildScope.map((s, i) => (
            <article class="scope__cell">
              <span class="scope__n">0{i + 1}</span>
              <h3>{s.label}</h3>
              <p>{s.note}</p>
            </article>
          ))
        }
      </div>

      <div class="bands">
        {
          buildBands.map((b) => (
            <article class="band">
              <div class="band__top">
                <h3 class="band__name">{b.name}</h3>
                <span class="band__price">{b.price}</span>
              </div>
              <p class="band__for">{b.for}</p>
            </article>
          ))
        }
      </div>
      <p class="bands__note">
        Bigger restaurants (extensive menus, on-site capture, full brand
        identity, multiple locations) run higher. We'll always scope it with
        you first.
      </p>
    </div>
  </section>

  <!-- ── Own it vs. rent it ── -->
  <section id="compare" class="section">
    <div class="container">
      <header class="head head--center">
        <p class="kicker">Own it, don't rent it</p>
        <h2>The math the rental crowd won't show you.</h2>
      </header>

      <div class="compare">
        <table class="compare__table">
          <thead>
            <tr>
              <th></th>
              <th>
                <span class="compare__co">{comparison.rivalLabel}</span>
                <span class="compare__sub">{comparison.rivalSub}</span>
              </th>
              <th class="compare__foh">
                <span class="compare__co">{comparison.fohLabel}</span>
                <span class="compare__sub">{comparison.fohSub}</span>
              </th>
            </tr>
          </thead>
          <tbody>
            {
              comparison.rows.map((r) => (
                <tr>
                  <th scope="row">{r.label}</th>
                  <td>{r.rival}</td>
                  <td class="compare__foh">{r.foh}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
        <p class="compare__foot">{comparison.footnote}</p>
      </div>
    </div>
  </section>

  <section class="section--tight">
    <div class="container">
      <div class="finenote">
        <p>
          Your AI assistant, Maître, is included with Care. It runs on our own
          local models, so there's no metered per-message billing and no
          surprise overages. Changes you or Maître submit are reviewed and built
          by our team before they go live, so nothing breaks. And every Care
          plan includes your exit kit: leave whenever you want and we hand you
          your full code.
        </p>
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section id="faq" class="section">
    <div class="container">
      <header class="head head--center">
        <h2>Questions about pricing</h2>
      </header>
      <div class="faq-list">
        {
          faq.pricing.map((item) => (
            <details class="faq-item">
              <summary class="faq-q">{item.q}</summary>
              <p class="faq-a">{item.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand
    heading="Not sure what your build runs?"
    sub="Tell us about your restaurant and we'll scope it: the build, and whether Care or Care+ fits."
  />
</Base>

<style>
  .phead {
    padding-block: clamp(3rem, 7vw, 5rem) clamp(1.5rem, 3vw, 2.5rem);
    text-align: center;
  }
  .phead h1 {
    margin-inline: auto;
  }
  .phead .lede {
    margin: 1.2rem auto 0;
  }
  .pricing-body {
    text-align: center;
  }
  .pricing-body :global(.tiers),
  .pricing-body :global(.buildpill),
  .pricing-body :global(.loc) {
    text-align: left;
  }
  .pricing-body :global(.tiers) {
    margin-inline: auto;
  }

  .head--center {
    margin-inline: auto;
    text-align: center;
    max-width: 640px;
    margin-bottom: 2.6rem;
  }
  .head--center .lede {
    margin-top: 0.8rem;
  }

  /* ── Build scope ── */
  .scope {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .scope__cell {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 1.8rem;
  }
  .scope__n {
    font-family: var(--display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--ember);
  }
  .scope__cell h3 {
    font-size: 1.2rem;
    margin: 0.5rem 0 0.4rem;
  }
  .scope__cell p {
    margin: 0;
    font-size: 0.92rem;
    color: var(--body);
  }

  /* ── Build bands ── */
  .bands {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .band {
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 1.5rem 1.6rem;
    background: var(--paper);
  }
  .band__top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
  }
  .band__name {
    font-size: 1.15rem;
    margin: 0;
  }
  .band__price {
    font-family: var(--display);
    font-weight: 700;
    color: var(--ember);
    white-space: nowrap;
  }
  .band__for {
    margin: 0;
    font-size: 0.9rem;
    color: var(--body);
  }
  .bands__note {
    margin: 1.4rem 0 0;
    font-size: 0.88rem;
    color: var(--muted);
    max-width: 70ch;
  }

  /* ── Comparison ── */
  .compare {
    max-width: 760px;
    margin-inline: auto;
  }
  .compare__table {
    width: 100%;
    border-collapse: collapse;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
  }
  .compare__table th,
  .compare__table td {
    padding: 0.95rem 1.1rem;
    text-align: left;
    font-size: 0.92rem;
    border-bottom: 1px solid var(--line);
  }
  .compare__table thead th {
    vertical-align: bottom;
    background: var(--bone);
  }
  .compare__table tbody th {
    font-weight: 600;
    color: var(--muted);
    width: 26%;
  }
  .compare__table tbody td {
    color: var(--body);
  }
  .compare__co {
    display: block;
    font-family: var(--display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--ink);
  }
  .compare__sub {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-top: 0.15rem;
  }
  .compare__foh {
    background: rgba(199, 91, 57, 0.06);
  }
  td.compare__foh {
    font-weight: 600;
    color: var(--ink);
  }
  .compare__table tr:last-child th,
  .compare__table tr:last-child td {
    border-bottom: 0;
  }
  .compare__foot {
    margin: 1rem 0 0;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .faq-list {
    max-width: 740px;
    margin-inline: auto;
  }
  .faq-item {
    border-bottom: 1px solid var(--line);
  }
  .faq-q {
    cursor: pointer;
    padding: 1.2rem 0;
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--ink);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .faq-q::after {
    content: "+";
    font-size: 1.3rem;
    color: var(--ember);
    flex: none;
    transition: transform 0.2s ease;
  }
  .faq-item[open] .faq-q::after {
    content: "−";
  }
  .faq-q::-webkit-details-marker {
    display: none;
  }
  .faq-a {
    padding: 0 0 1.2rem;
    color: var(--body);
    max-width: 65ch;
    margin: 0;
  }

  .finenote {
    border-top: 1px solid var(--line);
    padding-top: 1.5rem;
  }
  .finenote p {
    color: var(--muted);
    font-size: 0.85rem;
    max-width: 80ch;
    margin: 0;
  }

  @media (max-width: 760px) {
    .scope,
    .bands {
      grid-template-columns: 1fr;
    }
    .compare__table th,
    .compare__table td {
      padding: 0.7rem 0.75rem;
      font-size: 0.85rem;
    }
  }
</style>
