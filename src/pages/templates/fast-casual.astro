---
// Spec demo: "Stacked", counter-service smashburgers and bowls.
// Brief in TEMPLATES-DESIGN.md §2. Order-first: the order CTA floats,
// the menu board is the centerpiece. Archivo display, Inter body.
import "@fontsource-variable/archivo";
import archivoUrl from "@fontsource-variable/archivo/files/archivo-latin-wght-normal.woff2?url";
import { Image } from "astro:assets";
import DemoShell from "../../layouts/DemoShell.astro";
import { templateBySlug } from "../../data/templates";
import boardPhoto from "../../assets/demo/stacked-board.jpg";

const t = templateBySlug("fast-casual");

const board = [
  {
    cat: "Smash burgers",
    items: [
      { name: "The Classic", build: "Two patties, american, pickles, stack sauce", price: "9" },
      { name: "Double Trouble", build: "Four patties, double american, grilled onion", price: "12" },
      { name: "Crispy Chick", build: "Buttermilk thigh, slaw, hot honey", price: "11" },
      { name: "Garden Smash", build: "Black bean patty, avocado, chipotle mayo", price: "10" },
    ],
  },
  {
    cat: "Bowls",
    items: [
      { name: "Chop Chop", build: "Romaine, grilled chicken, corn, cotija, lime ranch", price: "12" },
      { name: "Harvest", build: "Farro, roast sweet potato, kale, tahini", price: "13" },
      { name: "Hot Honey Crunch", build: "Crispy chicken, rice, pickled jalapeño, honey", price: "13" },
    ],
  },
  {
    cat: "Sides & drinks",
    items: [
      { name: "Crinkle Fries", build: "Plain or cajun dusted", price: "4" },
      { name: "Halloumi Bites", build: "Fried squeaky cheese, zhug", price: "7" },
      { name: "House Lemonade", build: "Classic, strawberry, or arnold palmer", price: "4" },
      { name: "Fountain & cans", build: "The usual suspects, always cold", price: "3" },
    ],
  },
];
---

<DemoShell
  t={t}
  description="Fast casual spec template by Front of House: an order-first counter service site. Try it with your restaurant's name."
  preloadFont={archivoUrl}
>
  <div class="fs">
    <!-- ── Header ── -->
    <header class="fs-head">
      <p class="fs-head__brand"><span data-slot="name">{t.demoName}</span><span class="fs-stop" aria-hidden="true">.</span></p>
      <nav class="fs-head__nav" aria-label="Restaurant">
        <a href="#menu">Menu</a>
        <a href="#how">How it works</a>
        <a href="#visit">Find us</a>
      </nav>
      <a class="fs-btn" href="#menu">Order ahead</a>
    </header>

    <!-- ── Hero ── -->
    <section class="fs-hero">
      <div class="fs-hero__text">
        <p class="fs-hero__open" data-reveal style="--i:0">
          <span class="fs-hero__dot" aria-hidden="true"></span>
          Open till 9 tonight · <span data-slot="city">{t.demoCity}</span>
        </p>
        <h1 data-reveal style="--i:1">
          <span data-slot="name">{t.demoName}</span><span class="fs-stop" aria-hidden="true">.</span>
        </h1>
        <p class="fs-hero__tag" data-reveal style="--i:2">
          <span data-slot="tagline">{t.demoTagline}</span>
        </p>
        <div class="fs-hero__ctas" data-reveal style="--i:3">
          <a class="fs-btn fs-btn--big" href="#menu">Order ahead</a>
          <a class="fs-btn fs-btn--ghost fs-btn--big" href="#menu">See the board</a>
        </div>
        <p class="fs-hero__chip" data-reveal style="--i:4">
          <span class="fs-chip__dot" aria-hidden="true"></span>
          Line right now: about four minutes
        </p>
      </div>
      <figure class="fs-hero__ph">
        <Image
          src={boardPhoto}
          alt="The classic burger with crispy potatoes and house salsa on a board"
          widths={[480, 760, 1100]}
          sizes="(max-width: 860px) 100vw, 36rem"
        />
        <figcaption>The classic, board and all</figcaption>
      </figure>
    </section>

    <!-- ── Signature: the menu board ── -->
    <section class="fs-menu" id="menu">
      <header class="fs-menu__head">
        <h2>The board</h2>
        <p>Order at the counter, the app, or the window. Same board everywhere.</p>
      </header>
      <div class="fs-board">
        {
          board.map((col) => (
            <div class="fs-board__col">
              <h3>{col.cat}</h3>
              <ul>
                {col.items.map((item) => (
                  <li>
                    <div class="fs-item__row">
                      <span class="fs-item__name">{item.name}</span>
                      <span class="fs-item__dots" aria-hidden="true" />
                      <span class="fs-item__price">{item.price}</span>
                    </div>
                    <p class="fs-item__build">{item.build}</p>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <!-- ── Three-step strip ── -->
    <section class="fs-steps" id="how">
      <div class="fs-step">
        <span class="fs-step__n">1</span>
        <h3>Order</h3>
        <p>Counter, app, or pickup window. No wrong answers.</p>
      </div>
      <div class="fs-step">
        <span class="fs-step__n">2</span>
        <h3>Four minutes</h3>
        <p>In line to fed. The grill never stops.</p>
      </div>
      <div class="fs-step">
        <span class="fs-step__n">3</span>
        <h3>Eat</h3>
        <p>Here, the park across the street, or your couch.</p>
      </div>
    </section>

    <!-- ── Visit / footer ── -->
    <footer class="fs-visit" id="visit">
      <div class="fs-visit__grid">
        <div>
          <h2><span data-slot="name">{t.demoName}</span><span class="fs-stop" aria-hidden="true">.</span></h2>
          <p class="fs-visit__tag" data-slot="tagline">{t.demoTagline}</p>
        </div>
        <div>
          <h3>The counter</h3>
          <p>45 Peachtree Place<br /><span data-slot="city">{t.demoCity}</span></p>
        </div>
        <div>
          <h3>Hours</h3>
          <p>Every day<br />11:00 to 9:00</p>
        </div>
        <div>
          <h3>Order</h3>
          <p>(555) 010-0045<br />Pickup window on the side</p>
        </div>
      </div>
      <p class="fs-visit__fine">
        <span data-slot="name">{t.demoName}</span> ·
        <span data-slot="city">{t.demoCity}</span> · Counter service, good manners
      </p>
    </footer>

    <!-- Floating order pill: the order CTA is never off screen -->
    <a class="fs-fab" href="#menu">Order ahead</a>
  </div>
</DemoShell>

<style is:global>
  /* ── Stacked tokens: two vibes, switched by data-vibe on #demo-root ── */
  #demo-root[data-vibe="bold"] {
    --bg: #fff8ec;
    --surface: #ffffff;
    --fg: #1a1613;
    --muted: #7a7062;
    --hair: #eadfca;
    --accent: #c93a29;
    --on-accent: #fff8ec;
    --fill: #ffc93c;
    --on-fill: #1a1613;
    --ph: linear-gradient(150deg, #f2b53a 0%, #e39a24 100%);
  }
  #demo-root[data-vibe="fresh"] {
    --bg: #f3f8ef;
    --surface: #ffffff;
    --fg: #17211a;
    --muted: #5f6c5f;
    --hair: #dce7d4;
    --accent: #2e7d4f;
    --on-accent: #f3f8ef;
    --fill: #dff0c8;
    --on-fill: #17211a;
    --ph: linear-gradient(150deg, #cfe6b4 0%, #b3d494 100%);
  }

  .fs {
    --display: "Archivo Variable", "Archivo", "Helvetica Neue", sans-serif;
    --sans: "Inter Variable", "Inter", "Helvetica Neue", sans-serif;
    background: var(--bg);
    color: var(--fg);
    font-family: var(--sans);
    font-size: 1rem;
    line-height: 1.6;
    transition: background-color 0.35s ease, color 0.35s ease;
  }
  .fs h1,
  .fs h2,
  .fs h3 {
    font-family: var(--display);
    color: var(--fg);
  }
  /* The brand full stop: always the accent, always there. */
  .fs-stop {
    color: var(--accent);
  }

  .fs :focus-visible {
    outline: 2.5px solid var(--accent);
    outline-offset: 3px;
  }

  .fs-btn {
    display: inline-block;
    font-family: var(--display);
    font-weight: 800;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--on-accent);
    background: var(--accent);
    border: 2px solid var(--accent);
    border-radius: 10px;
    padding: 0.6rem 1.2rem;
    text-decoration: none;
    transition: transform 0.12s ease, filter 0.18s ease;
  }
  .fs-btn:hover {
    filter: brightness(0.92);
  }
  .fs-btn:active {
    transform: translateY(2px);
  }
  .fs-btn--ghost {
    background: transparent;
    color: var(--fg);
    border-color: var(--fg);
  }
  .fs-btn--big {
    font-size: 1.02rem;
    padding: 0.8rem 1.6rem;
  }

  /* ── Header ── */
  .fs-head {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    padding: 1rem clamp(1.2rem, 5vw, 3.5rem);
    border-bottom: 2px solid var(--fg);
  }
  .fs-head__brand {
    font-family: var(--display);
    font-weight: 900;
    font-size: 1.45rem;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }
  .fs-head__nav {
    display: flex;
    gap: 1.3rem;
    margin-left: auto;
  }
  .fs-head__nav a {
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    color: var(--fg);
    text-decoration: none;
  }
  .fs-head__nav a:hover {
    color: var(--accent);
  }

  /* ── Hero ── */
  .fs-hero {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(2.5rem, 7vw, 5.5rem) clamp(1.2rem, 5vw, 2rem);
  }
  .fs-hero__open {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--muted);
    margin-bottom: 0.9rem;
  }
  .fs-hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex: none;
  }
  .fs-hero h1 {
    font-size: clamp(3.4rem, 10vw, 6.5rem);
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .fs-hero__tag {
    display: inline-block;
    font-family: var(--display);
    font-size: clamp(0.95rem, 1.6vw, 1.1rem);
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--fill);
    color: var(--on-fill);
    padding: 0.45rem 0.8rem;
    max-width: 34ch;
    margin-bottom: 1.6rem;
  }
  .fs-hero__ctas {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .fs-hero__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 1.4rem;
    border: 2px solid var(--fg);
    border-radius: 999px;
    padding: 0.45rem 1rem;
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  .fs-chip__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent);
    flex: none;
    animation: fs-pulse 1.8s ease-in-out infinite;
  }
  @keyframes fs-pulse {
    50% {
      opacity: 0.35;
      transform: scale(0.8);
    }
  }
  .fs-hero__ph {
    position: relative;
    margin: 0;
    background: var(--ph);
    border: 2px solid var(--fg);
    border-radius: 18px;
    aspect-ratio: 4 / 3.4;
    overflow: hidden;
  }
  .fs-hero__ph img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .fs-hero__ph::after {
    content: "";
    position: absolute;
    inset: 60% 0 0;
    background: linear-gradient(to bottom, transparent, rgba(20, 15, 10, 0.5));
    pointer-events: none;
  }
  .fs-hero__ph figcaption {
    position: absolute;
    left: 1.1rem;
    bottom: 0.9rem;
    z-index: 1;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff8ec;
  }

  /* ── The board ── */
  .fs-menu {
    background: var(--surface);
    border-block: 2px solid var(--fg);
    padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1.2rem, 5vw, 2rem);
    transition: background-color 0.35s ease;
  }
  .fs-menu__head {
    max-width: 72rem;
    margin: 0 auto clamp(1.8rem, 4vw, 2.8rem);
  }
  .fs-menu__head h2 {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }
  .fs-menu__head p {
    color: var(--muted);
    font-weight: 500;
  }
  .fs-board {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.6rem, 4vw, 3rem);
    max-width: 72rem;
    margin: 0 auto;
  }
  .fs-board__col h3 {
    display: inline-block;
    font-size: 0.86rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    background: var(--fill);
    color: var(--on-fill);
    border-radius: 6px;
    padding: 0.3rem 0.65rem;
    margin-bottom: 1.1rem;
  }
  .fs-board__col ul {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .fs-item__row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .fs-item__name {
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  .fs-item__dots {
    flex: 1;
    border-bottom: 2px dotted var(--hair);
    transform: translateY(-3px);
  }
  .fs-item__price {
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .fs-item__build {
    font-size: 0.88rem;
    color: var(--muted);
    margin-top: 0.15rem;
  }

  /* ── Steps ── */
  .fs-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.4rem, 4vw, 3rem);
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1.2rem, 5vw, 2rem);
  }
  .fs-step__n {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    background: var(--fg);
    color: var(--bg);
    font-family: var(--display);
    font-weight: 800;
    margin-bottom: 0.7rem;
  }
  .fs-step h3 {
    font-size: 1.25rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    margin-bottom: 0.3rem;
  }
  .fs-step p {
    color: var(--muted);
    font-weight: 500;
    margin: 0;
  }

  /* ── Visit / footer ── */
  .fs-visit {
    background: var(--fg);
    color: var(--bg);
    padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1.2rem, 5vw, 3.5rem) 5.5rem;
  }
  .fs-visit__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: clamp(1.6rem, 4vw, 3rem);
    max-width: 72rem;
    margin: 0 auto;
  }
  .fs-visit h2 {
    color: var(--bg);
    font-size: clamp(1.8rem, 3.6vw, 2.4rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }
  .fs-visit__tag {
    opacity: 0.75;
    font-weight: 500;
  }
  .fs-visit h3 {
    color: var(--bg);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 0.5rem;
  }
  .fs-visit p {
    opacity: 0.92;
  }
  .fs-visit__fine {
    max-width: 72rem;
    margin: clamp(2rem, 4vw, 3rem) auto 0;
    padding-top: 1.1rem;
    border-top: 1px solid color-mix(in srgb, var(--bg) 25%, transparent);
    font-size: 0.8rem;
    opacity: 0.7;
  }

  /* ── Floating order pill ── */
  .fs-fab {
    position: fixed;
    left: 50%;
    bottom: 1.1rem;
    transform: translateX(-50%);
    z-index: 40;
    font-family: var(--display);
    font-weight: 800;
    font-size: 0.95rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--on-accent);
    background: var(--accent);
    border-radius: 999px;
    padding: 0.75rem 1.7rem;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.22);
    transition: transform 0.12s ease;
  }
  .fs-fab:active {
    transform: translateX(-50%) translateY(2px);
  }

  @media (max-width: 860px) {
    .fs-hero {
      grid-template-columns: 1fr;
    }
    .fs-board {
      grid-template-columns: 1fr;
    }
    .fs-steps {
      grid-template-columns: 1fr;
    }
    .fs-visit__grid {
      grid-template-columns: 1fr 1fr;
    }
    .fs-head {
      flex-wrap: wrap;
      gap: 0.8rem 1.2rem;
    }
    .fs-head__nav {
      order: 3;
      width: 100%;
    }
  }
  @media (max-width: 460px) {
    .fs-visit__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
